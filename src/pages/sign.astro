---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import PdfSignTool from '../components/PdfSignTool.jsx';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import { FileSignature } from 'lucide-preact';

const title = 'Sign PDF Free - Fill Forms, No Sign-Up, Runs Locally | PDkef';
const description = 'Sign PDF files online for free. Add signatures, fill forms, write text, and check boxes in your browser securely. Your files never leave your device.';

// FAQ schema mirrors the visible FAQ rendered below.
const faq = [
  {
    question: 'Do I need to create an account to sign a PDF?',
    answer: 'No. Unlike DocuSign, Adobe Sign, or other e-signature platforms, there is no signup, no email verification, and no trial period. Open the tool and start signing immediately.'
  },
  {
    question: 'Can I sign school trip agreements?',
    answer: 'Yes. This tool is perfect for child school trip agreements, consent slips, and standard PDF forms. You can type the child\'s name, tick the consent checkboxes, and draw your parent signature.'
  },
  {
    question: 'Is my signature safe here?',
    answer: 'Absolutely. Unlike standard PDF signing websites that upload your signature and PDF file to their servers, this tool runs entirely on your device. There is no account and no server-side copy of your document to retain or breach - your signature image is embedded in the PDF in-memory and never leaves your computer or phone.'
  },
  {
    question: 'Can I type my signature instead of drawing?',
    answer: 'Yes. If you don\'t want to draw with a mouse or touch, you can select the "Type" option. It renders your name in a handwriting font and embeds it as a signature.'
  },
  {
    question: 'What happens if my browser crashes while filling out a form?',
    answer: 'Your work is not lost. As you add text, checkmarks, and signatures, the tool auto-saves your progress to local storage in your own browser, and restores it automatically the next time you open the tool on the same device. Because this happens on your device, your file is still never uploaded, and your saved draft is only cleared when you click Start over.'
  }
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef - Sign PDF" description={description} faq={faq} />
  </Fragment>

  <header>
    <div class="page-title-row">
      <div class="page-icon"><FileSignature size={28} strokeWidth={2} /></div>
      <h1>Sign &amp; Fill PDF Free: No Sign-Up, Runs Locally</h1>
    </div>
    <p>Fill out forms, tick checkboxes, type text, and add your signature to any PDF - school consent slips, contracts, and applications. Your progress is auto-saved on your device, so a crash or accidental refresh never loses your work.</p>
  </header>

  <main>
    <section id="app" aria-label="PDF sign tool">
      <PdfSignTool client:load />
    </section>
  </main>

  <Footer summaryText="Fill out and sign PDFs securely in your browser. No upload, no servers. 100% private.">
    <section id="how-it-works">
      <h2>How to fill and sign PDF files</h2>
      <ol>
        <li><strong>Upload your form.</strong> Select or drag-and-drop the PDF document you want to fill and sign.</li>
        <li><strong>Add text & signatures.</strong> Click to place text blocks, checkmarks, or signatures on the pages.</li>
        <li><strong>Sign with ease.</strong> Draw your signature on screen, type it out using a cursive font, or upload a signature image.</li>
        <li><strong>Position & resize.</strong> Drag items to place them exactly where they belong in the agreement.</li>
        <li><strong>Save & download.</strong> Click Sign and Download PDF to generate and download your completed document.</li>
      </ol>
    </section>

    <section id="why-privacy">
      <h2>100% private and offline-first</h2>
      <ul>
        <li><strong>No account, ever:</strong> no signup, no email verification, no trial period - other e-signature tools gate downloads behind an account, this one doesn't.</li>
        <li><strong>No server, no paywalls:</strong> documents are processed 100% locally, right in your browser on a computer or phone - no upload, and no premium tier hiding the features you need.</li>
        <li><strong>HIPAA & GDPR safe:</strong> Since files never cross the network, this is the most secure way to sign confidential parent forms, child health forms, or school agreements.</li>
        <li><strong>No watermarks:</strong> Save your signed files for free without any watermarks or page limits.</li>
        <li><strong>Auto-saved on your device:</strong> your progress is saved as you fill the form and restored if your browser crashes or you reload, with nothing uploaded. Most online editors can't recover your work without storing your file on their servers - this one recovers it while keeping the file private.</li>
        <li><strong>Open source:</strong> the entire codebase is public and MIT licensed - inspect exactly what runs on your device.</li>
      </ul>
    </section>

    <section id="faq">
      <h2>Frequently asked questions</h2>
      <h3>Do I need to create an account to sign a PDF?</h3>
      <p>No. Unlike DocuSign, Adobe Sign, or other e-signature platforms, there is no signup, no email verification, and no trial period. Open the tool and start signing immediately.</p>
      <h3>Can I sign school trip agreements?</h3>
      <p>Yes. This tool is perfect for child school trip agreements, consent slips, and standard PDF forms. You can type the child's name, tick the consent checkboxes, and draw your parent signature.</p>
      <h3>Is my signature safe here?</h3>
      <p>Absolutely. Unlike standard PDF signing websites that upload your signature and PDF file to their servers, this tool runs entirely on your device. There is no account and no server-side copy of your document to retain or breach - your signature image is embedded in the PDF in-memory and never leaves your computer or phone.</p>
      <h3>Can I type my signature instead of drawing?</h3>
      <p>Yes. If you don't want to draw with a mouse or touch, you can select the "Type" option. It renders your name in a handwriting font and embeds it as a signature.</p>
      <h3>What happens if my browser crashes while filling out a form?</h3>
      <p>Your work is not lost. As you add text, checkmarks, and signatures, the tool auto-saves your progress to local storage in your own browser, and restores it automatically the next time you open the tool on the same device. Because this happens on your device, your file is still never uploaded, and your saved draft is only cleared when you click Start over.</p>
    </section>
  </Footer>
</BaseLayout>
