---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import PdfRedactTool from '../components/PdfRedactTool.jsx';
import Footer from '../components/Footer.astro';
import BrandBack from '../components/BrandBack.astro';
import '../styles/global.css';
import { Eraser } from 'lucide-preact';

const title = 'Blackout, Blur, or Redact PDF Online | Free & Private';
const description =
  'Securely hide text in your PDF files. Black out or blur sensitive information, and we permanently flatten the page so the data cannot be extracted. 100% private.';

const faq = [
  {
    question: 'Are my PDF files uploaded to a server?',
    answer:
      'No. PDkef runs entirely in your browser. Your file is never uploaded, never sent over the network, and never stored anywhere outside your own device.',
  },
  {
    question: 'How is this different from just drawing a black box?',
    answer:
      'Many free tools just draw a layer over the text, meaning anyone can still copy-paste the text hidden underneath. We perform "True Redaction": the page is converted into a flattened image, permanently destroying the underlying text data so it is impossible to recover.',
  },
  {
    question: 'How do I blackout or blur text in a PDF?',
    answer:
      'Load your PDF, choose "Blackout" or "Blur" from the toolbar, then click and drag on any page to draw a box over the sensitive information. Once you have covered all sensitive areas, click Redact PDF. The tool will flatten the edited pages and generate your secure PDF.',
  },
  {
    question: 'Is there a file size limit?',
    answer:
      'There are no artificial limits. However, because redacted pages are converted to high-quality images, your final file size may be larger than the original document.',
  },
  {
    question: 'If my browser crashes mid-redaction, do I lose my boxes?',
    answer:
      'No. As you draw blackout and blur boxes, the tool auto-saves your progress to local storage in your own browser, and restores your boxes automatically the next time you open the tool on the same device. This happens on your device, so your file is still never uploaded, and your saved draft is only cleared when you click Start over.',
  },
];
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef - Redact PDF" description={description} faq={faq} />
  </Fragment>

  <header>
    <div class="page-header-row">
      <div class="page-title-block">
        <div class="page-title-row">
          <div class="page-icon"><Eraser size={28} strokeWidth={2} /></div>
          <h1>Redact PDF Free: No Sign-Up, Runs Locally</h1>
        </div>
        <p>
      Black out or blur sensitive text like SSNs and addresses, then flatten the file so it can't be copied or extracted. Your redaction boxes are auto-saved on your device as you work, so a crash or accidental refresh never loses your progress.
    </p>
      </div>
      <BrandBack />
    </div>
  </header>

  <main>
    <section id="app" aria-label="Redact PDF tool">
      <PdfRedactTool client:load />
    </section>
  </main>

  <Footer summaryText="Permanently hide, blackout, blur, and flatten sensitive information in your PDFs directly in your browser. No uploads, absolute privacy.">
    <section id="how-it-works">
      <h2>How to blackout or blur a PDF securely</h2>
      <ol>
        <li>
          <strong>Open your PDF.</strong> Click "Choose file" or drag and drop any PDF into the tool.
          Your file stays on your device - nothing is uploaded.
        </li>
        <li>
          <strong>Draw boxes.</strong>
          Choose your style (solid blackout or blurred out), then click and drag with your mouse over the text you want to hide.
        </li>
        <li>
          <strong>Apply &amp; download.</strong> Click Redact PDF. The tool flattens those specific pages, destroying the underlying text data so it can never be extracted or copy-pasted, and downloads the secure PDF.
        </li>
      </ol>
    </section>

    <section id="faq">
      <h2>Frequently asked questions</h2>

      <h3>Are my PDF files uploaded to a server?</h3>
      <p>
        No. PDkef runs entirely in your browser. Your file is never uploaded, never sent over the
        network, and never stored anywhere outside your own device.
      </p>

      <h3>How is this different from just drawing a black box?</h3>
      <p>
        Many free tools just draw a layer over the text, meaning anyone can still copy-paste the text hidden underneath. We perform "True Redaction": the page is converted into a flattened image, permanently destroying the underlying text data so it is impossible to recover.
      </p>

      <h3>How do I blur text in a PDF?</h3>
      <p>
        Load your PDF, select "Blur" from the style toggle above the pages, then click and drag on any page to draw a blur box over the sensitive information. Once you have covered all sensitive areas, click Redact PDF. The tool will flatten the blurred pages and generate your secure PDF.
      </p>

      <h3>Is there a file size limit?</h3>
      <p>
        There are no artificial limits. However, because redacted pages are converted to high-quality images, your final file size may be larger than the original document.
      </p>

      <h3>If my browser crashes mid-redaction, do I lose my boxes?</h3>
      <p>
        No. As you draw blackout and blur boxes, the tool auto-saves your progress to local storage in your own browser, and restores your boxes automatically the next time you open the tool on the same device. This happens on your device, so your file is still never uploaded, and your saved draft is only cleared when you click Start over.
      </p>
    </section>
  </Footer>
</BaseLayout>
