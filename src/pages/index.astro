---
import BaseLayout from '../layouts/BaseLayout.astro';
import SeoSchema from '../components/SeoSchema.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

const title = 'Sign & Fill PDF Free - No Sign-Up Local PDF Editor | PDkef';
const description = 'Sign PDFs and fill interactive forms instantly with this 100% free, open-source online PDF editor that requires no account or software installation. With secure browser-local processing, files are never uploaded to an external server, providing a completely private, offline-capable workflow.';

import { FileSignature, Merge, ImageUp, ImageDown, Split, Shrink, FileLock2, FileEdit, Eraser } from 'lucide-preact';

// FAQ schema mirrors the visible questions rendered in the footer below.
const faq = [
  { question: 'Are the tools really free?', answer: 'Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.' },
  { question: 'Do I need to sign up or create an account?', answer: 'No. There is no account, no email, and no trial period. Open a tool and use it immediately.' },
  { question: 'Are my files uploaded to a server?', answer: 'No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.' },
  { question: 'Is PDkef open source?', answer: 'Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.' },
];

// Ordered by SEO priority score from the keyword research (search volume x
// winnability x client-side fit) - highest-opportunity tools surface first.
const tools = [
  {
    title: 'Sign & Fill PDF',
    description: 'Fill interactive PDF forms and draw secure digital signatures instantly in your browser with zero registration, zero limits, and no watermarks.',
    href: '/sign/',
    icon: FileSignature
  },
  {
    title: 'Merge PDF',
    description: 'Combine multiple PDFs into a single document in seconds.',
    href: '/merge/',
    icon: Merge
  },
  {
    title: 'PDF to Image',
    description: 'Convert PDF pages into high-quality JPG or PNG images.',
    href: '/pdf-to-image/',
    icon: ImageUp
  },
  {
    title: 'Image to PDF',
    description: 'Combine JPG or PNG images into a single PDF document.',
    href: '/image-to-pdf/',
    icon: ImageDown
  },
  {
    title: 'Split PDF',
    description: 'Extract specific pages or separate a PDF into multiple files.',
    href: '/split/',
    icon: Split
  },
  {
    title: 'Compress PDF',
    description: 'Reduce the file size of your PDF without losing quality.',
    href: '/compress/',
    icon: Shrink
  },
  {
    title: 'Protect & Unlock',
    description: 'Add a password to secure your PDF or remove a known password.',
    href: '/unlock/',
    icon: FileLock2
  },
  {
    title: 'Edit PDF Pages',
    description: 'Remove, rotate, and add page numbers to your PDF file easily.',
    href: '/edit-pdf/',
    icon: FileEdit
  },
  {
    title: 'Redact & Blur',
    description: 'Securely hide, blur, or black out sensitive text and flatten the document.',
    href: '/redact/',
    icon: Eraser
  }
];

const HeroIcon = tools[0].icon;
---

<BaseLayout title={title} description={description}>
  <Fragment slot="head">
    <SeoSchema name="PDkef" description={description} faq={faq} />
  </Fragment>

  <header class="hub-header">
    <div class="title-row">
      <img src="/favicon.png" width="42" height="42" aria-hidden="true" class="title-logo" alt="PDkef Logo" style="border-radius: 8px;" />
      <h1>PDkef - all the PDF tools you need</h1>
    </div>
    <p>100% open source and free, with no sign up and no paywalls - ever. Every tool runs locally in your browser, on your computer or your phone.</p>
  </header>

  <main>
    {/* Hero Card for the first tool */}
    {tools.length > 0 && (
      <a href={tools[0].href} class="hero-card">
        <div class="hero-info">
          <span class="hero-badge">Local & Private</span>
          <h2>
            <HeroIcon size={24} strokeWidth={2.5} style="display: inline-block; vertical-align: text-bottom; margin-right: 0.5rem; color: var(--color-primary);" />
            {tools[0].title}
          </h2>
          <p>{tools[0].description}</p>
          <span class="hero-cta">
            Open tool
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="5" y1="12" x2="19" y2="12"></line>
              <polyline points="12 5 19 12 12 19"></polyline>
            </svg>
          </span>
        </div>
        <div class="hero-visual" aria-hidden="true">
          <div class="doc-mockup">
            <div class="doc-line short"></div>
            <div class="doc-line"></div>
            <div class="doc-line medium"></div>
            <div class="doc-sig-row">
              <div class="doc-sig-label">Sign here:</div>
              <div class="doc-sig-line">
                <svg class="cursive-signature" viewBox="0 0 100 30" fill="none" stroke="var(--color-primary)" stroke-width="2.2" stroke-linecap="round">
                  <path d="M10,20 Q25,5 35,22 T55,12 T75,25 T90,10" />
                </svg>
              </div>
            </div>
          </div>
          <div class="pen-mockup">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 20h9" />
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
            </svg>
          </div>
        </div>
      </a>
    )}

    {/* 4x2 Grid for the remaining 8 tools */}
    <div class="tool-grid">
      {tools.slice(1).map((tool) => (
        <a href={tool.href} class="tool-card">
          <div class="tool-icon">
            <tool.icon size={24} strokeWidth={2} />
          </div>
          <div class="tool-content">
            <h3>{tool.title}</h3>
            <p>{tool.description}</p>
          </div>
        </a>
      ))}
    </div>
  </main>

  <script>
    // PWA installation handling
    let installPrompt = null;
    const installBtn = document.getElementById('install-pwa');
    const installHint = document.getElementById('install-pwa-hint');

    const isStandalone =
      window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone === true;

    if (installBtn && !isStandalone) {
      installBtn.style.display = 'inline-flex';

      window.addEventListener('beforeinstallprompt', (e) => {
        e.preventDefault();
        installPrompt = e;
      });

      installBtn.addEventListener('click', async () => {
        if (installPrompt) {
          installPrompt.prompt();
          const { outcome } = await installPrompt.userChoice;
          if (outcome === 'accepted') {
            installPrompt = null;
            installBtn.style.display = 'none';
          }
          return;
        }
        // No native install prompt available on this browser (e.g. any
        // browser on iOS, which is WebKit-only and never fires
        // beforeinstallprompt) - point the user at the manual flow instead.
        // Always (re-)show rather than toggle, so a second tap still gives
        // visible feedback instead of silently hiding the hint.
        installHint.style.display = 'block';
        installHint.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
    }
  </script>

  <Footer>
    <section id="why-us">
      <h2>Why yet another PDF tool?</h2>
      <p>Most free PDF sites run your file through their own servers - which costs them money, so they claw it back with task limits, watermarks, or a forced signup. PDkef is different: it's 100% open source, runs entirely on your device, and is free to use forever - no sign up, no paywalls.</p>
      <ul>
        <li><strong>Free, forever:</strong> no cost, no paywalls, no premium tier hiding the tools you actually need.</li>
        <li><strong>No sign up:</strong> no account, no email, no trial period - open a tool and use it.</li>
        <li><strong>No server:</strong> every tool runs locally, right in your browser, on a computer or a phone.</li>
        <li><strong>No limits:</strong> no watermarks, no daily caps, no page restrictions.</li>
        <li><strong>Open source:</strong> the entire codebase is public and MIT licensed - inspect exactly what runs on your device.</li>
      </ul>
    </section>

    <section id="faq">
      <h2>Frequently asked questions</h2>
      <h3>Are the tools really free?</h3>
      <p>Yes, completely and permanently - no paywalls, no premium tier, no limits, and no watermark on your exported PDFs.</p>
      <h3>Do I need to sign up or create an account?</h3>
      <p>No. There is no account, no email, and no trial period. Open a tool and use it immediately.</p>
      <h3>Are my files uploaded to a server?</h3>
      <p>No. The tools run 100% locally in your browser, on desktop or mobile. Your PDF files are never sent over the network - they stay on your device the entire time.</p>
      <h3>Is PDkef open source?</h3>
      <p>Yes. The entire codebase is open source under the MIT license, so you can inspect exactly what runs on your device.</p>
    </section>

    <div slot="how-it-works-extra" style="margin-top: 1.5rem;">
      <button id="install-pwa" class="install-pwa-button" style="display: none;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        Install as local app
      </button>
      <p id="install-pwa-hint" class="hint-message" role="status" style="display: none;">
        Open your browser's menu and choose "Add to Home Screen" (iOS Safari/Chrome) or "Install app" (Android) to install PDkef.
      </p>
    </div>
  </Footer>
</BaseLayout>

<style>
  .hub-header {
    padding: 3.5rem 1.5rem 2rem;
  }
  
  .title-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-bottom: 0.75rem;
  }
  
  .title-logo {
    flex-shrink: 0;
  }

  .hub-header h1 {
    margin-bottom: 0;
    text-align: left;
  }

  .hero-card {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    padding: 2rem 2.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    margin-bottom: 2rem;
    box-shadow: var(--shadow-sm);
    position: relative;
    overflow: hidden;
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
  }

  .hero-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 12px 24px -8px var(--color-primary-ring);
    border-color: var(--color-primary-soft);
  }

  .hero-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.65rem;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.75rem;
    background: var(--color-primary-soft);
    color: var(--color-primary);
    border-radius: var(--radius-pill);
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .hero-info h2 {
    font-size: 1.75rem;
    font-weight: 800;
    margin: 0;
    color: var(--color-text);
    letter-spacing: -0.02em;
    display: flex;
    align-items: center;
  }

  .hero-info p {
    font-size: 0.95rem;
    line-height: 1.5;
    margin: 0;
    color: var(--color-muted);
    max-width: 560px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-top: 0.25rem;
    transition: gap 0.2s var(--ease-out);
  }

  .hero-card:hover .hero-cta {
    gap: 0.75rem;
  }

  .hero-visual {
    position: relative;
    width: 200px;
    height: 120px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .doc-mockup {
    width: 150px;
    height: 105px;
    background: var(--color-surface);
    border: 1.5px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    padding: 1rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    transition: border-color 0.3s var(--ease-out), transform 0.3s var(--ease-out);
  }

  .hero-card:hover .doc-mockup {
    border-color: var(--color-primary-soft);
    transform: scale(1.02);
  }

  .doc-line {
    height: 5px;
    background: var(--color-border-strong);
    border-radius: 3px;
    width: 100%;
  }

  .doc-line.short { width: 40%; }
  .doc-line.medium { width: 75%; }

  .doc-sig-row {
    margin-top: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
  }

  .doc-sig-label {
    font-size: 0.65rem;
    color: var(--color-muted-light);
    font-weight: 500;
  }

  .doc-sig-line {
    flex: 1;
    border-bottom: 1px dashed var(--color-muted-light);
    height: 14px;
    position: relative;
  }

  .cursive-signature {
    position: absolute;
    bottom: -2px;
    left: 4px;
    width: 60px;
    height: 20px;
    color: var(--color-primary);
  }

  .pen-mockup {
    position: absolute;
    right: 15px;
    bottom: 5px;
    width: 28px;
    height: 28px;
    background: var(--color-surface);
    border: 1px solid var(--color-border-strong);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary);
    box-shadow: var(--shadow-sm);
    transform: rotate(-15deg);
    transition: transform 0.3s var(--ease-spring), border-color 0.3s var(--ease-out);
  }

  .hero-card:hover .pen-mockup {
    transform: rotate(0deg) translate(-2px, -2px);
    border-color: var(--color-primary);
  }

  .pen-mockup svg {
    width: 14px;
    height: 14px;
  }

  .tool-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 1fr;
    gap: 1.5rem;
  }

  @media (max-width: 1024px) {
    .tool-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .hero-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    .hero-visual {
      display: none;
    }
  }

  @media (max-width: 640px) {
    .tool-grid {
      grid-template-columns: 1fr;
    }
  }

  .tool-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    color: inherit;
    box-shadow: var(--shadow-sm);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s var(--ease-out), border-color 0.4s var(--ease-out);
    position: relative;
    overflow: hidden;
  }

  .tool-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-primary-tint) 0%, transparent 70%);
    opacity: 0;
    transition: opacity 0.4s var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  .tool-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md), 0 12px 24px -8px var(--color-primary-ring);
    border-color: var(--color-border-strong);
  }

  .tool-card:hover::before {
    opacity: 1;
  }

  .tool-icon, .tool-content {
    position: relative;
    z-index: 1;
  }

  .tool-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius);
    background: #d4e2fc; /* A tone darker than primary-soft */
    color: var(--color-primary);
    margin-bottom: 1.25rem;
    transition: transform 0.2s var(--ease-spring), background-color 0.2s var(--ease-out);
  }

  .tool-card:hover .tool-icon {
    background: var(--color-primary);
    color: white;
    transform: scale(1.05);
  }

  .tool-content h3 {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.5rem;
    color: var(--color-text);
  }

  .tool-content p {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.5;
    color: var(--color-muted);
  }
</style>
